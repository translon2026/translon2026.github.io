  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      // --- MOBILE NAVIGATION LOGIC ---
      const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      function toggleMenu() {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('flex');
        if (mobileMenu.classList.contains('hidden')) {
          menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger Icon
        } else {
          menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X Close Icon
        }
      }

      mobileMenuToggle.addEventListener('click', toggleMenu);
      mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

      document.querySelectorAll('[data-detail-card]').forEach(card => {
        const panelId = card.getAttribute('aria-controls');
        const panel = panelId ? document.getElementById(panelId) : null;
        const label = card.querySelector('.detail-toggle-label');
        const collapsedLabel = label ? label.textContent : '';
        const expandedLabel = collapsedLabel.startsWith('Contact') ? 'Hide contact' : 'Hide details';

        function toggleDetailPanel() {
          if (!panel) return;

          const isExpanded = card.getAttribute('aria-expanded') === 'true';
          card.setAttribute('aria-expanded', (!isExpanded).toString());
          panel.classList.toggle('hidden', isExpanded);
          if (label) {
            label.textContent = isExpanded ? collapsedLabel : expandedLabel;
          }
        }

        card.addEventListener('click', toggleDetailPanel);
        card.addEventListener('keydown', event => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            toggleDetailPanel();
          }
        });
      });


      // --- INTERSECTION OBSERVER FOR FADE IN EFFECTS ---
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, { 
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
      });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));


      // --- SVG ANIMATION LOGIC ---
      const svgCanvas = document.getElementById("animation-canvas"); 
      const scene = document.getElementById("scene");
      const basesGroup = document.getElementById("mrna-bases");
      const trnaLayer = document.getElementById("trna-layer");
      const ribosome = document.getElementById("ribosome");
      const mrnaBackbone = document.getElementById("mrna-backbone");
      
      const proteinThread = document.getElementById("nascent-protein-thread");
      const proteinBalls = document.getElementById("nascent-protein-balls");
      
      const baseSpacing = 30; // Distance between letters
      const codonSize = baseSpacing * 3; // EXACTLY 90px (Perfect match to E, P, A site rectangles)
      const trnaCycleDuration = 1100;
      
      const totalBases = Math.floor(document.body.scrollHeight / baseSpacing) + 50; 

      function getViewportWidth() {
        return window.innerWidth || document.documentElement.clientWidth || svgCanvas.getBoundingClientRect().width || 0;
      }

      function getViewportHeight() {
        return window.innerHeight || document.documentElement.clientHeight || svgCanvas.getBoundingClientRect().height || 0;
      }
      
      // Cache viewport dimensions to prevent mobile URL-bar hiding from causing "jumps".
      // Use viewport/document metrics instead of SVG clientWidth, which is unreliable in Safari.
      let canvasWidth = getViewportWidth();
      let viewportHeight = getViewportHeight();
      let isMobile = canvasWidth < 768;

      function getStrandXPercent() {
        const layoutWidth = window.innerWidth || canvasWidth;
        if (layoutWidth < 480) return 0.86;
        if (layoutWidth < 768) return 0.92;
        if (layoutWidth < 1024) return 0.86;
        return 0.83;
      }

      function getAnimationScale() {
        const layoutWidth = window.innerWidth || canvasWidth;
        return lerp(0.54, 1, clamp01((layoutWidth - 360) / 664));
      }

      let strandXPercent = getStrandXPercent();
      let animationScale = getAnimationScale();

      // Initialize base positions
      mrnaBackbone.setAttribute("x1", `${strandXPercent * 100}%`);
      mrnaBackbone.setAttribute("x2", `${strandXPercent * 100}%`);

      const nucleotides = [
        { letter: 'A', color: '#3b82f6', bg: '#eff6ff' }, 
        { letter: 'C', color: '#059669', bg: '#ecfdf5' }, 
        { letter: 'U', color: '#0ea5e9', bg: '#f0f9ff' }, 
        { letter: 'G', color: '#7e22ce', bg: '#f3e8ff' }  
      ];

      for (let i = 0; i < totalBases; i++) {
        const yPos = i * baseSpacing + 15; 
        const nuc = nucleotides[Math.floor(Math.random() * nucleotides.length)];
        
        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.classList.add("mrna-base-circle");
        circle.setAttribute("cx", `${strandXPercent * 100}%`);
        circle.setAttribute("cy", yPos.toString());
        circle.setAttribute("r", "10");
        circle.setAttribute("fill", nuc.bg);
        circle.setAttribute("stroke", nuc.color);
        circle.setAttribute("stroke-width", "2");
        
        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.classList.add("mrna-base-text");
        text.setAttribute("x", `${strandXPercent * 100}%`);
        text.setAttribute("y", (yPos + 4).toString());
        text.setAttribute("text-anchor", "middle");
        text.setAttribute("font-size", "10");
        text.setAttribute("font-weight", "bold");
        text.setAttribute("fill", nuc.color);
        text.textContent = nuc.letter;

        basesGroup.appendChild(circle);
        basesGroup.appendChild(text);
      }

      function createSvgElement(tag, attrs = {}) {
        const element = document.createElementNS("http://www.w3.org/2000/svg", tag);
        Object.entries(attrs).forEach(([key, value]) => element.setAttribute(key, value));
        return element;
      }

      const trnaLocal = {
        amino: { x: 38, y: -58 },
        anticodon: { x: -22, y: 36 }
      };
      const dockedTRNARotation = -90;

      function createTRNA(className, color) {
        const group = createSvgElement("g", { class: className });

        const backbone = createSvgElement("path", {
          class: "trna-backbone",
          d: "M 38 -58 C 18 -59, 2 -54, -10 -44 C -23 -32, -29 -16, -29 3 L -29 29 C -29 43, -15 51, -4 42 C 5 35, 4 24, -8 24 C -19 24, -25 31, -22 36 C -24 16, -22 -4, -14 -20 C -8 -33, -4 -40, -10 -44 C 1 -31, 16 -22, 33 -17 C 47 -13, 50 4, 39 15 C 29 25, 11 22, -1 10",
          fill: "none",
          stroke: color,
          "stroke-width": "9.5",
          "stroke-linecap": "round",
          "stroke-linejoin": "round",
          filter: "url(#trna-shadow)",
          opacity: "0.84",
          "vector-effect": "non-scaling-stroke"
        });

        const highlight = createSvgElement("path", {
          d: "M 29 -54 C 14 -54, 1 -50, -10 -39 C -20 -27, -24 -11, -24 8 M -2 -38 C 8 -29, 21 -22, 35 -18",
          fill: "none",
          stroke: "#ffffff",
          "stroke-width": "2.5",
          "stroke-linecap": "round",
          "stroke-linejoin": "round",
          opacity: "0.5",
          "vector-effect": "non-scaling-stroke"
        });

        const aminoLink = createSvgElement("line", {
          class: "trna-amino-link",
          x1: "25",
          y1: "-58",
          x2: trnaLocal.amino.x.toString(),
          y2: trnaLocal.amino.y.toString(),
          stroke: "#64748b",
          "stroke-width": "2",
          "stroke-linecap": "round",
          "vector-effect": "non-scaling-stroke"
        });

        const aminoAcid = createSvgElement("circle", {
          class: "trna-amino-acid",
          cx: trnaLocal.amino.x.toString(),
          cy: trnaLocal.amino.y.toString(),
          r: "7",
          fill: color,
          stroke: "#ffffff",
          "stroke-width": "2.2",
          filter: "url(#bead-shadow)"
        });

        group.append(backbone, highlight, aminoLink, aminoAcid);
        trnaLayer.appendChild(group);

        return { group, aminoLink, aminoAcid, coloredElements: [backbone] };
      }

      const trnas = {
        incoming: createTRNA("trna-incoming", "#f97316"),
        peptidyl: createTRNA("trna-peptidyl", "#8b5cf6"),
        exiting: createTRNA("trna-exiting", "#0ea5e9")
      };
      const trnaPalette = ["#f97316", "#8b5cf6", "#0ea5e9", "#10b981", "#eab308"];

      const peptideBondBridge = createSvgElement("path", {
        fill: "none",
        stroke: "#ec4899",
        "stroke-width": "3",
        "stroke-linecap": "round",
        "stroke-dasharray": "5 7",
        opacity: "0"
      });
      trnaLayer.appendChild(peptideBondBridge);

      const chainTerminus = createSvgElement("circle", {
        r: "8",
        fill: "#ec4899",
        stroke: "#ffffff",
        "stroke-width": "2.5",
        filter: "url(#bead-shadow)",
        opacity: "0"
      });
      trnaLayer.appendChild(chainTerminus);

      let currentRibosomeY = codonSize / 2;
      let lastCodonIndex = 0;
      let trnaCycleStart = performance.now();
      let animationFrameId = null;
      let lastSceneScrollY = null;
      let lastProteinPathUpdate = 0;
      let cachedProteinThreadD = "";
      let cachedProteinBallsD = "";

      function requestAnimationLoop() {
        if (animationFrameId === null) {
          animationFrameId = requestAnimationFrame(updateAnimation);
        }
      }

      // Handle Device Rotation / Major Resizing Safely
      window.addEventListener('resize', () => {
        // Only update logic if the WIDTH changes significantly (ignores mobile vertical scroll URL bar toggles!)
        const nextCanvasWidth = getViewportWidth();
        if (Math.abs(nextCanvasWidth - canvasWidth) > 30) {
          canvasWidth = nextCanvasWidth;
          viewportHeight = getViewportHeight();
          isMobile = canvasWidth < 768;
          strandXPercent = getStrandXPercent();
          animationScale = getAnimationScale();

          mrnaBackbone.setAttribute("x1", `${strandXPercent * 100}%`);
          mrnaBackbone.setAttribute("x2", `${strandXPercent * 100}%`);
          document.querySelectorAll('.mrna-base-circle').forEach(c => c.setAttribute("cx", `${strandXPercent * 100}%`));
          document.querySelectorAll('.mrna-base-text').forEach(t => t.setAttribute("x", `${strandXPercent * 100}%`));
          cachedProteinThreadD = "";
          cachedProteinBallsD = "";
        }
        requestAnimationLoop();
      });

      window.addEventListener('scroll', requestAnimationLoop, { passive: true });

      function lerp(start, end, amount) {
        return start + (end - start) * amount;
      }

      function easeInOut(t) {
        return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
      }

      function clamp01(value) {
        return Math.min(1, Math.max(0, value));
      }

      function setTRNAState(trna, x, y, scale, rotation, opacity, aminoOpacity = 1) {
        trna.group.setAttribute("transform", `translate(${x}, ${y}) rotate(${rotation}) scale(${scale})`);
        trna.group.setAttribute("opacity", opacity.toString());
        trna.aminoLink.setAttribute("opacity", aminoOpacity.toString());
        trna.aminoAcid.setAttribute("opacity", aminoOpacity.toString());
        trna.state = { x, y, scale, rotation };
      }

      function setTRNAColor(trna, color) {
        if (trna.color === color) return;
        trna.color = color;
        trna.coloredElements.forEach(element => element.setAttribute("stroke", color));
        trna.aminoAcid.setAttribute("fill", color);
      }

      function localPointToCanvas(trna, point) {
        const state = trna.state || { x: 0, y: 0, scale: 1, rotation: 0 };
        return localPointWithState(point, state);
      }

      function localPointWithState(point, state) {
        const radians = state.rotation * Math.PI / 180;
        const scaledX = point.x * state.scale;
        const scaledY = point.y * state.scale;
        return {
          x: state.x + scaledX * Math.cos(radians) - scaledY * Math.sin(radians),
          y: state.y + scaledX * Math.sin(radians) + scaledY * Math.cos(radians)
        };
      }

      function translationForLocalPoint(point, target, scale, rotation) {
        const radians = rotation * Math.PI / 180;
        const scaledX = point.x * scale;
        const scaledY = point.y * scale;

        return {
          x: target.x - (scaledX * Math.cos(radians) - scaledY * Math.sin(radians)),
          y: target.y - (scaledX * Math.sin(radians) + scaledY * Math.cos(radians))
        };
      }

      function updateAnimation() {
        animationFrameId = null;
        const now = performance.now();
        const scrollY = window.scrollY;
        
        // Calculate maxScroll using the CACHED viewportHeight
        const maxScroll = Math.max(1, document.body.scrollHeight - viewportHeight);
        const scrollProgress = Math.min(1, Math.max(0, scrollY / maxScroll));
        
        if (scrollY !== lastSceneScrollY) {
          scene.setAttribute("transform", `translate(0, -${scrollY})`);
          lastSceneScrollY = scrollY;
        }
        
        // Parallax math uses CACHED viewportHeight, completely eliminating the mobile jump!
        const parallaxY = viewportHeight * 0.35 + (scrollProgress * viewportHeight * 0.3);
        const dynamicCenterPoint = scrollY + parallaxY;
        
        // 3-CODON LOCK (Guarantees exactly 3 bases sit perfectly inside the 90px E/P/A rectangles)
        const k = Math.round((dynamicCenterPoint - (codonSize / 2)) / codonSize);
        const maxK = Math.floor(totalBases / 3) - 2;
        const clampedK = Math.max(0, Math.min(k, maxK));
        const targetRibosomeY = clampedK * codonSize + (codonSize / 2);

        if (clampedK !== lastCodonIndex) {
          lastCodonIndex = clampedK;
          trnaCycleStart = now;
        }
        
        currentRibosomeY += (targetRibosomeY - currentRibosomeY) * 0.1;
        
        const riboX = canvasWidth * strandXPercent; 
        
        ribosome.setAttribute("transform", `translate(${riboX}, ${currentRibosomeY}) rotate(-90) scale(${animationScale})`);

        const cycleProgress = Math.min(1, (now - trnaCycleStart) / trnaCycleDuration);
        const approachEase = easeInOut(clamp01(cycleProgress / 0.34));
        const transferStart = 0.34;
        const transferEnd = 0.54;
        const transferProgress = clamp01((cycleProgress - transferStart) / (transferEnd - transferStart));
        const transferEase = easeInOut(transferProgress);
        const translocEase = easeInOut(clamp01((cycleProgress - 0.58) / 0.30));
        const leaveEase = easeInOut(clamp01((cycleProgress - 0.88) / 0.12));

        const trnaScale = (isMobile ? 0.54 : 0.68) * Math.sqrt(animationScale);
        const siteOffset = codonSize;
        const anticodonContactX = riboX - (isMobile ? 13 : 16) * animationScale;
        const aSiteY = currentRibosomeY + siteOffset;
        const pSiteY = currentRibosomeY;
        const eSiteY = currentRibosomeY - siteOffset;
        const aDock = translationForLocalPoint(trnaLocal.anticodon, { x: anticodonContactX, y: aSiteY }, trnaScale, dockedTRNARotation);
        const pDock = translationForLocalPoint(trnaLocal.anticodon, { x: anticodonContactX, y: pSiteY }, trnaScale, dockedTRNARotation);
        const eDock = translationForLocalPoint(trnaLocal.anticodon, { x: anticodonContactX, y: eSiteY }, trnaScale, dockedTRNARotation);

        const incomingStartX = aDock.x - (isMobile ? 78 : 115) * animationScale;
        const incomingStartY = aDock.y + (isMobile ? 52 : 72) * animationScale;
        const incomingDockX = lerp(incomingStartX, aDock.x, approachEase);
        const incomingDockY = lerp(incomingStartY, aDock.y, approachEase);
        const incomingX = lerp(incomingDockX, pDock.x, translocEase);
        const incomingY = lerp(incomingDockY, pDock.y, translocEase);
        const peptidylDockX = lerp(pDock.x, eDock.x, translocEase);
        const peptidylDockY = lerp(pDock.y, eDock.y, translocEase);
        const peptidylExitX = eDock.x - (isMobile ? 78 : 112) * animationScale;
        const peptidylExitY = eDock.y - (isMobile ? 42 : 58) * animationScale;
        const peptidylX = lerp(peptidylDockX, peptidylExitX, leaveEase);
        const peptidylY = lerp(peptidylDockY, peptidylExitY, leaveEase);
        const peptidylColor = trnaPalette[clampedK % trnaPalette.length];
        const incomingColor = trnaPalette[(clampedK + 1) % trnaPalette.length];

        setTRNAColor(trnas.incoming, incomingColor);
        setTRNAColor(trnas.peptidyl, peptidylColor);
        setTRNAColor(trnas.exiting, peptidylColor);

        setTRNAState(
          trnas.incoming,
          incomingX,
          incomingY,
          trnaScale,
          lerp(-56, dockedTRNARotation, approachEase),
          Math.min(1, cycleProgress / 0.16),
          1
        );

        setTRNAState(
          trnas.peptidyl,
          peptidylX,
          peptidylY,
          trnaScale,
          lerp(dockedTRNARotation, dockedTRNARotation - 18, leaveEase),
          0.86 * (1 - leaveEase),
          1 - transferEase
        );

        setTRNAState(
          trnas.exiting,
          eDock.x,
          eDock.y,
          trnaScale,
          dockedTRNARotation,
          0,
          0
        );

        const oldPeptidylAnchor = localPointToCanvas(trnas.peptidyl, trnaLocal.amino);
        const incomingAnchor = localPointToCanvas(trnas.incoming, trnaLocal.amino);
        const pSitePeptideAnchor = localPointWithState(trnaLocal.amino, {
          x: pDock.x,
          y: pDock.y,
          scale: trnaScale,
          rotation: dockedTRNARotation
        });
        const bridgeControlX = (oldPeptidylAnchor.x + incomingAnchor.x) / 2 - (isMobile ? 18 : 28) * animationScale;
        const bridgeControlY = (oldPeptidylAnchor.y + incomingAnchor.y) / 2 - (isMobile ? 22 : 34) * animationScale;
        const bridgeOpacity = transferProgress > 0 && transferProgress < 1 ? 0.55 : 0;

        peptideBondBridge.setAttribute("d", `M ${oldPeptidylAnchor.x} ${oldPeptidylAnchor.y} Q ${bridgeControlX} ${bridgeControlY}, ${incomingAnchor.x} ${incomingAnchor.y}`);
        peptideBondBridge.setAttribute("opacity", bridgeOpacity.toString());

        // Keep the visible nascent chain fixed sideways at the P-site exit point;
        // elongation is shown by the growing chain while the tRNAs move through the sites.
        const shouldUpdateProteinPath = !isMobile || !cachedProteinThreadD || now - lastProteinPathUpdate > 33;
        if (shouldUpdateProteinPath) {
          const proteinMiddleX = canvasWidth * (isMobile ? 0.20 : 0.35);
          let pathD = `M ${proteinMiddleX} 0 `;
          const step = 80;

          for (let y = step; y < currentRibosomeY - 120; y += step) {
            const waveAmp = canvasWidth * (isMobile ? 0.06 : 0.12);
            const slowWave = Math.sin(y / 180) * waveAmp;
            const midWave = Math.cos(y / 70) * (isMobile ? 50 : 90);
            const fastWave = Math.sin(y / 30) * (isMobile ? 25 : 40);
            const xOffset = slowWave + midWave + fastWave;
            const yOffset = Math.sin(y / 60) * 50;

            const currentX = proteinMiddleX + xOffset;
            const currentY = y + yOffset;
            const cpX = currentX - Math.sin(y / 50) * (isMobile ? 70 : 120);
            const cpY = currentY - (step * 0.8);

            pathD += `S ${cpX} ${cpY}, ${currentX} ${currentY} `;
          }

          const tunnelX = riboX - (isMobile ? 42 : 72) * animationScale;
          const tunnelY = currentRibosomeY - (isMobile ? 24 : 38) * animationScale;
          const chainAnchor = pSitePeptideAnchor;
          const tunnelPath = `Q ${riboX - (isMobile ? 95 : 150) * animationScale} ${currentRibosomeY - (isMobile ? 12 : 20) * animationScale}, ${tunnelX} ${tunnelY} `;
          cachedProteinBallsD = pathD + tunnelPath;
          pathD += tunnelPath;
          pathD += `Q ${(tunnelX + chainAnchor.x) / 2} ${Math.min(tunnelY, chainAnchor.y) - (isMobile ? 10 : 14) * animationScale}, ${chainAnchor.x} ${chainAnchor.y}`;
          cachedProteinThreadD = pathD;
          lastProteinPathUpdate = now;
        }
        
        proteinThread.setAttribute("d", cachedProteinThreadD);
        proteinBalls.setAttribute("d", cachedProteinBallsD);
        chainTerminus.setAttribute("opacity", "0");

        if (Math.abs(targetRibosomeY - currentRibosomeY) > 0.15 || cycleProgress < 1) {
          requestAnimationLoop();
        }
      }
      
      requestAnimationLoop();
    });
  </script>
</body>
</html>
