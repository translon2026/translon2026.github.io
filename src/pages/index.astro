        </div>
        <div class="grid grid-cols-3 md:grid-cols-4 gap-4 text-sm border-b border-slate-100 pb-3 items-center">
          <div class="font-semibold text-slate-500 bg-slate-100 inline-block px-3 py-1 rounded-full w-max">9:00 - 9:15</div>
          <div class="col-span-2 md:col-span-3 text-slate-700">Welcome and opening remarks</div>
        </div>
        <div class="grid grid-cols-3 md:grid-cols-4 gap-4 text-sm bg-blue-50/80 border border-blue-100 p-3 rounded-lg items-center">
          <div class="font-bold text-blue-800">9:15 - 12:30</div>
          <div class="col-span-2 md:col-span-3 font-bold text-blue-900 text-base">Session 1: Regulation & Architecture</div>
        </div>
