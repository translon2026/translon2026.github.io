            <div class="w-16 h-16 min-w-[4rem] bg-gradient-to-br from-blue-100 to-purple-100 rounded-full flex items-center justify-center text-purple-600 font-black text-xl shadow-inner group-hover:scale-110 transition-transform duration-300">
              {speaker.name !== "To be announced" ? speaker.name.charAt(0) : "?"}
